# Copy this file to .env in the project root and fill in your values.
# Or place your real .env at C:\Users\Buxe\Projects\Neuer Ordner\.env and copy/link it here,
# or start the server with ENV_PATH="C:/Users/Buxe/Projects/Neuer Ordner/.env".

# Gemini / Google GenAI
GEMINI_API_KEY=your_gemini_api_key_here

# Emlalock API credentials
EMLA_USER_ID=your_emla_user_id
EMLA_API_KEY=your_emla_api_key
EMLA_HOLDER_KEY=your_emla_holder_key

# SMTP / Email bridge
SMTP_HOST=mail.gmx.net
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
LYRA_USER_EMAIL=target@example.com
LYRA_ENABLE_EMAIL_BRIDGE=true
LYRA_ENABLE_EMAIL_AMBUSH=true
LYRA_MAX_DAILY_EMAILS=3

# Optional external voice endpoint
COLAB_VOICE_URL=https://parakeet-unrest-cane.ngrok-free.dev

# Local video library path
VIDEO_LIBRARY_DIR=C:/Users/Buxe/Projects/Neuer Ordner/Videos
