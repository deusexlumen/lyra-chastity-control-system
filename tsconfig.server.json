{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist-server",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "types": ["node"]
  },
  "include": ["server.ts", "sessionEngine.ts", "src/lib/stateManager.ts", "src/lib/moduleLoader.ts", "src/types/engine.ts"]
}
